{% extends "_layout.twig" %}

{% block body %}
	<h3>Emplacement</h3>
	<hr>

	<div class="card">
		<div class="card-body">
			<h5 class="card-title">{{ emplacement.libelle }}</h5>
			<p><strong>Description :</strong> {{ emplacement.description }}</p>
			<p><strong>Image :</strong> {{ emplacement.image }}</p>
		</div>
	</div>

	<div class="mt-3">
		<a href="/admin/emplacements" class="btn btn-secondary">Retour</a>
		<a href="/admin/emplacements/emplacement_modification-{{ emplacement.id }}" class="btn btn-warning">Modifier</a>
	</div>
{% endblock %}