{% extends "_layout.twig" %}

{% block body %}

	<h3>Détail de l'équipement</h3>
	<hr>

	{% if equipement %}
		<div class="card">
			<div class="card-header">
				<h5 class="card-title mb-0">{{ equipement.libelle }}</h5>
			</div>
			<div class="card-body">
				<div class="row">
					<div class="col-md-6">
						<p><strong>Référence :</strong> {{ equipement.reference }}</p>
						<p><strong>Code :</strong> {{ equipement.code }}</p>
						<p><strong>Catégorie :</strong> 
							{% if equipement.categorie %}
								{{ equipement.categorie.libelle }}
							{% else %}
								<span class="text-muted">Non définie</span>
							{% endif %}
						</p>
						<p><strong>EPI :</strong>
							{% if equipement.categorie and equipement.categorie.est_epi %}
								<span class="badge bg-success">Oui</span>
							{% elseif equipement.categorie and not equipement.categorie.est_epi %}
								<span class="badge bg-secondary">Non</span>
							{% else %}
								<span class="text-muted">Non défini</span>
							{% endif %}
						</p>
						<p><strong>Emplacement :</strong> 
							{% if equipement.emplacement %}
								{{ equipement.emplacement.libelle }}
							{% else %}
								<span class="text-muted">Non défini</span>
							{% endif %}
						</p>
						<p><strong>Date de mise en service :</strong> 
							{% if equipement.date_mise_en_service %}
								{{ equipement.date_mise_en_service|date("d/m/Y") }}
							{% else %}
								<span class="text-muted">Non renseignée</span>
							{% endif %}
						</p>
						<p><strong>Date de fin d'utilisation :</strong> 
							{% if not equipement.date_fin_utilisation or equipement.date_fin_utilisation > "now"|date("Y-m-d") %}
							<span class="text-muted">
								Toujours en service
								{% if equipement.date_fin_utilisation %}
								({{ equipement.date_fin_utilisation|date("d/m/Y") }})
								{% endif %}
							</span>
							{% else %}
							{{ equipement.date_fin_utilisation|date("d/m/Y") }}
							{% endif %}
						</p>
					</div>
					<div class="col-md-6">
						<p><strong>Statut :</strong> 
							{% if equipement.statut == 0 %}
								<span class="badge bg-success">Disponible</span>
							{% elseif equipement.statut == 1 %}
								<span class="badge bg-warning">En maintenance</span>
							{% elseif equipement.statut == 2 %}
								<span class="badge bg-danger">Hors service</span>
							{% else %}
								<span class="badge bg-secondary">Inconnu</span>
							{% endif %}
						</p>
						<p><strong>État :</strong> 
							{% if equipement.etat %}
								{{ equipement.etat }}
							{% else %}
								<span class="text-muted">Non défini</span>
							{% endif %}
						</p>
						<p><strong>Date dernier contrôle :</strong> 
							{% if equipement.date_dernier_controle %}
								{{ equipement.date_dernier_controle|date("d/m/Y") }}
							{% else %}
								<span class="text-muted">Jamais contrôlé</span>
							{% endif %}
						</p>
						<p><strong>Remarques :</strong> 
							{% if equipement.remarques %}
								{{ equipement.remarques }}
							{% else %}
								<span class="text-muted">Aucune remarque</span>
							{% endif %}
						</p>

						{# Affichage de la photo #}
						{% if equipement.photo is defined and equipement.photo is not empty %}
							<div class="mt-2">
								<strong>Photo :</strong>
								<div>
									<img src="{{ equipement.photo }}" alt="Photo de l'équipement" style="max-width: 300px; max-height: 300px;" class="img-thumbnail">
								</div>
							</div>
						{% endif %}
					</div>
				</div>
			</div>
		</div>

		{# --- Historique des contrôles --- #}
		{% if historiqueControles %}
			<div class="card mt-4">
				<div class="card-header bg-primary text-white">
					<h5 class="mb-0">📋 Historique des contrôles ({{ historiqueControles|length }})</h5>
				</div>
				<div class="card-body p-0">
					<div class="table-responsive">
						<table class="table table-striped mb-0">
							<thead>
								<tr>
									<th>Contrôle</th>
									<th>Date contrôle</th>
									<th>Contrôleur</th>
									<th>Statut</th>
									<th>Remarque</th>
									<th>Actions</th>
								</tr>
							</thead>
							<tbody>
								{% for ligne in historiqueControles %}
									<tr>
										<td>{{ ligne.controle_libelle }}</td>
										<td>
											{% if ligne.date_controle %}
												{{ ligne.date_controle|date("d/m/Y H:i") }}
											{% else %}
												<span class="text-muted">-</span>
											{% endif %}
										</td>
										<td>
											{{ ligne.controleur_prenom }} {{ ligne.controleur_nom }}
										</td>
										<td>
											{% set statutClasses = {
												'a_controler': 'warning',
												'controle_ok': 'success',
												'controle_ko': 'danger',
												'hors_service': 'secondary'
											} %}
											{% set statutLabels = {
												'a_controler': 'À contrôler',
												'controle_ok': 'OK',
												'controle_ko': 'KO',
												'hors_service': 'Hors service'
											} %}
											<span class="badge bg-{{ statutClasses[ligne.statut]|default('secondary') }}">
												{{ statutLabels[ligne.statut]|default(ligne.statut) }}
											</span>
										</td>
										<td>
											{% if ligne.remarque %}
												<span class="text-muted small" title="{{ ligne.remarque }}">
													{{ ligne.remarque|length > 50 ? ligne.remarque|slice(0, 50) ~ '...' : ligne.remarque }}
												</span>
											{% else %}
												<span class="text-muted">-</span>
											{% endif %}
										</td>
										<td>
											<a href="/journaux/{{ ligne.controle_id }}" class="btn btn-sm btn-primary" target="_blank">
												Voir le journal
											</a>
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		{% else %}
			<div class="card mt-4">
				<div class="card-header bg-secondary text-white">
					<h5 class="mb-0">📋 Historique des contrôles</h5>
				</div>
				<div class="card-body">
					<p class="text-muted mb-0">Cet équipement n'a pas encore été contrôlé ou aucun contrôle n'a été clôturé.</p>
				</div>
			</div>
		{% endif %}
		{# --- Fin historique --- #}

		<div class="mt-3">
			<a href="/equipements" class="btn btn-secondary">Retour à la liste</a>
			<a href="/equipements/equipement_modification-{{ equipement.id }}" class="btn btn-warning">Modifier</a>
		</div>
	{% else %}
		<div class="alert alert-warning">
			Équipement non trouvé.
		</div>
		<a href="/equipements" class="btn btn-secondary">Retour à la liste</a>
	{% endif %}

{% endblock %}