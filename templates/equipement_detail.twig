{% extends "_layout.twig" %}

{% block body %}

	<h3>Détail de l'équipement</h3>
	<hr>

	{% if equipement %}
		<div class="card">
			<div class="card-header">
				<h5 class="card-title mb-0">{{ equipement.libelle }}</h5>
			</div>
			<div class="card-body">
				<div class="row">
					<div class="col-md-6">
						<p><strong>Référence :</strong> {{ equipement.reference }}</p>
						<p><strong>Code :</strong> {{ equipement.code }}</p>
						<p><strong>Catégorie :</strong> 
							{% if equipement.categorie %}
								{{ equipement.categorie.libelle }}
							{% else %}
								<span class="text-muted">Non définie</span>
							{% endif %}
						</p>
						<p><strong>EPI :</strong>
							{% if equipement.categorie and equipement.categorie.est_epi %}
								<span class="badge bg-success">Oui</span>
							{% elseif equipement.categorie and not equipement.categorie.est_epi %}
								<span class="badge bg-secondary">Non</span>
							{% else %}
								<span class="text-muted">Non défini</span>
							{% endif %}
						</p>
						<p><strong>Emplacement :</strong> 
							{% if equipement.emplacement %}
								{{ equipement.emplacement.libelle }}
							{% else %}
								<span class="text-muted">Non défini</span>
							{% endif %}
						</p>
						<p><strong>Date de mise en service :</strong> 
							{% if equipement.date_mise_en_service %}
								{{ equipement.date_mise_en_service|date("d/m/Y") }}
							{% else %}
								<span class="text-muted">Non renseignée</span>
							{% endif %}
						</p>
						<p><strong>Date de fin d'utilisation :</strong> 
							{% if not equipement.date_fin_utilisation or equipement.date_fin_utilisation > "now"|date("Y-m-d") %}
							<span class="text-muted">
								Toujours en service
								{% if equipement.date_fin_utilisation %}
								({{ equipement.date_fin_utilisation|date("d/m/Y") }})
								{% endif %}
							</span>
							{% else %}
							{{ equipement.date_fin_utilisation|date("d/m/Y") }}
							{% endif %}
						</p>
					</div>
					<div class="col-md-6">
						<p><strong>Statut :</strong> 
							{% if equipement.statut == 0 %}
								<span class="badge bg-success">Disponible</span>
							{% elseif equipement.statut == 1 %}
								<span class="badge bg-warning">En maintenance</span>
							{% elseif equipement.statut == 2 %}
								<span class="badge bg-danger">Hors service</span>
							{% else %}
								<span class="badge bg-secondary">Inconnu</span>
							{% endif %}
						</p>
						<p><strong>État :</strong> 
							{% if equipement.etat %}
								{{ equipement.etat }}
							{% else %}
								<span class="text-muted">Non défini</span>
							{% endif %}
						</p>
						<p><strong>Date dernier contrôle :</strong> 
							{% if equipement.date_dernier_controle %}
								{{ equipement.date_dernier_controle|date("d/m/Y") }}
							{% else %}
								<span class="text-muted">Jamais contrôlé</span>
							{% endif %}
						</p>
						<p><strong>Remarques :</strong> 
							{% if equipement.remarques %}
								{{ equipement.remarques }}
							{% else %}
								<span class="text-muted">Aucune remarque</span>
							{% endif %}
						</p>

						{# ⬇️ NOUVEAU : Affichage de la photo #}
						{% if equipement.photo is defined and equipement.photo is not empty %}
							<div class="mt-2">
								<strong>Photo :</strong>
								<div>
									<img src="{{ equipement.photo }}" alt="Photo de l'équipement" style="max-width: 300px; max-height: 300px;" class="img-thumbnail">
								</div>
							</div>
						{% endif %}
						{# ⬆️ FIN NOUVEAU #}
					</div>
				</div>
			</div>
		</div>

		<div class="mt-3">
			<a href="/equipements" class="btn btn-secondary">Retour à la liste</a>
			<a href="/equipements/equipement_modification-{{ equipement.id }}" class="btn btn-warning">Modifier</a>
		</div>
	{% else %}
		<div class="alert alert-warning">
			Équipement non trouvé.
		</div>
		<a href="/equipements" class="btn btn-secondary">Retour à la liste</a>
	{% endif %}

{% endblock %}