{% extends "_layout.twig" %}

{% block body %}

	<h3>Liste des utilisateurs</h3>
	<hr>

	<div class="mb-3">
		<a href="/admin/utilisateurs/nouveau" class="btn btn-primary">➕ Nouvel utilisateur</a>
	</div>

	<table class="table table-striped">
		<thead>
			<tr>
				<th>ID</th>
				<th>Nom</th>
				<th>Prénom</th>
				<th>Pseudo</th>
				<th>Email</th>
				<th>Rôle</th>
				<th>Actions</th>
			</tr>
		</thead>
		<tbody>
			{% for utilisateur in utilisateurs %}
				<tr>
					<td>{{ utilisateur.id }}</td>
					<td>{{ utilisateur.nom }}</td>
					<td>{{ utilisateur.prenom }}</td>
					<td>{{ utilisateur.username }}</td>
					<td>{{ utilisateur.email }}</td>
					<td>{{ utilisateur.rolelabel }}</td>
					<td>
						<a href="/admin/utilisateurs/utilisateur-{{ utilisateur.id }}" class="btn btn-sm btn-primary">Voir</a>
						<a href="/admin/utilisateurs/utilisateur_supprimer-{{ utilisateur.id }}" 
						   onclick="return confirm('Supprimer {{ utilisateur.prenom }} {{ utilisateur.nom }} ?')" 
						   class="btn btn-sm btn-danger">Supprimer</a>
					</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

{% endblock %}