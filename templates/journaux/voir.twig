{# templates/journaux/voir.twig #}

{% extends "_layout.twig" %}

{% block body %}
	<h3>📄 Journal de contrôle #{{ controle.id }}</h3>
    <hr>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Informations du contrôle</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <strong>Contrôleur :</strong>
                    <p class="mb-0">{{ controle.controleur_prenom }} {{ controle.controleur_nom }}</p>
                </div>
                <div class="col-md-3">
                    <strong>Date début :</strong>
                    <p class="mb-0">{{ controle.date_debut|date("d/m/Y H:i") }}</p>
                </div>
                <div class="col-md-3">
                    <strong>Date fin :</strong>
                    <p class="mb-0">{{ controle.date_fin|date("d/m/Y H:i") }}</p>
                </div>
                <div class="col-md-3">
                    <strong>Créé par :</strong>
                    <p class="mb-0">{{ controle.cree_par_prenom }} {{ controle.cree_par_nom }}</p>
                </div>
            </div>
            {# Affichage des remarques générales après déchiffrement #}
            {% if controle.hash_remarques %}
            <div class="row mt-3">
                <div class="col-md-12">
                    <strong>Remarques générales :</strong>
                    <p class="mb-0">{{ controle.hash_remarques }}</p>
                </div>
            </div>
            {% endif %}
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Équipements contrôlés <span class="badge bg-secondary">{{ lignes|length }}</span></h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Référence</th>
                            <th>Code</th>
                            <th>Désignation</th>
                            <th>Catégorie</th>
                            <th>EPI</th>
                            <th>Emplacement</th>
                            <th>Date contrôle</th>
                            <th>Statut</th>
                            <th>Remarque</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for ligne in lignes %}
                            <tr>
                                <td><strong>{{ ligne.reference }}</strong></td>
                                <td><code>{{ ligne.equipement_code }}</code></td>
                                <td>{{ ligne.equipement_libelle }}</td>
                                <td>{{ ligne.categorie_libelle|default('N/A') }}</td>
                                <td>
                                    {% if ligne.est_epi %}
                                        <span class="badge bg-success">EPI</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Non EPI</span>
                                    {% endif %}
                                </td>
                                <td>{{ ligne.emplacement_libelle|default('Non défini') }}</td>
                                <td>
                                    {% if ligne.date_controle %}
                                        {{ ligne.date_controle|date("d/m/Y H:i") }}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% set statutClasses = {
                                        'a_controler': 'warning',
                                        'controle_ok': 'success',
                                        'controle_ko': 'danger',
                                        'hors_service': 'secondary'
                                    } %}
                                    {% set statutLabels = {
                                        'a_controler': 'À contrôler',
                                        'controle_ok': 'OK',
                                        'controle_ko': 'KO',
                                        'hors_service': 'Hors service'
                                    } %}
                                    <span class="badge bg-{{ statutClasses[ligne.statut] }}">
                                        {{ statutLabels[ligne.statut]|default(ligne.statut) }}
                                    </span>
                                </td>
                                <td>
                                    {% if ligne.remarque %}
                                        <span class="text-muted small" title="{{ ligne.remarque }}">
                                            {{ ligne.remarque|length > 50 ? ligne.remarque|slice(0, 50) ~ '...' : ligne.remarque }}
                                        </span>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">
                                    <i>Aucun équipement contrôlé dans ce journal</i>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <a href="/journaux" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Retour à la liste
        </a>
        <a href="/journaux/pdf/{{ controle.id }}" class="btn btn-primary">
            <i class="bi bi-download"></i> Télécharger en PDF
        </a>
    </div>
{% endblock %}