{% extends "_layout.twig" %}

{% block body %}
	<h3>{% if emplacement.id %}Modifier{% else %}Nouvel{% endif %} emplacement</h3>
	<hr>

	<form method="post">
		<div class="mb-3">
			<label for="libelle">Libellé *</label>
			<input type="text" id="libelle" name="libelle" value="{{ emplacement.libelle }}" class="form-control">
		</div>
		<div class="mb-3">
			<label for="description">Description</label>
			<textarea id="description" name="description" class="form-control" rows="3">{{ emplacement.description }}</textarea>
		</div>
		<div class="mb-3">
			<label for="image">Image (URL)</label>
			<input type="text" id="image" name="image" value="{{ emplacement.image }}" class="form-control">
		</div>
		<button type="submit" class="btn btn-primary">Enregistrer</button>
		<a href="/admin/emplacements" class="btn btn-secondary">Annuler</a>
	</form>
{% endblock %}