{% extends "_layout.twig" %}

{% block body %}

	<h3>Fiche Catégorie</h3>
	<hr>

	<div class="row h-100">
		<div class="col-md-6">
			{% if categorie.image %}
				<img src="/images/{{ categorie.image }}" alt="{{ categorie.libelle }}" class="img-fluid">
			{% endif %}
		</div>
		<div class="col-md-6">
			<div class="mb-3">
				<label for="libelle">Libellé :</label>
				{{ categorie.libelle }}
			</div>
			<div class="mb-3">
				{% set est_epi_value = "Oui" %}
				{% if categorie.est_epi == 0 %}
					{% set est_epi_value = "Non" %}
				{% endif %}
				<label for="est_epi">Classée EPI ? :</label>
				{{ est_epi_value }}
			</div>
			<div class="mb-3">
				<label for="description">Description :</label>
				{{ categorie.description }}
			</div>
			<div class="mb-3 d-flex gap-2">
				<a href="/admin/categories" class="btn btn-secondary">Retour à la liste</a>
				<a href="/admin/categories/categorie_modification-{{ categorie.id }}" class="btn btn-warning">Modifier</a>
				<a href="/admin/categories/supprimer?id={{ categorie.id }}" 
				   onclick="return confirm('Êtes-vous sûr de vouloir supprimer la catégorie « {{ categorie.libelle }} » ? Cette action est irréversible.')" 
				   class="btn btn-danger ms-auto">🗑️ Supprimer</a>
			</div>
		</div>
	</div>
{% endblock %}