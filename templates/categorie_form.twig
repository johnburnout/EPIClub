{% extends "_layout.twig" %}

{% block body %}

	<h3>{% if categorie.id %}Modifier{% else %}Nouvelle{% endif %} catégorie</h3>
	<hr>

	<form method="post" enctype="multipart/form-data">
		<div class="mb-3">
			<label for="libelle">Libellé * :</label>
			<input type="text" id="libelle" name="libelle" value="{{ categorie.libelle }}" class="form-control">
		</div>

		<div class="mb-3">
			<label for="description">Description :</label>
			<textarea id="description" name="description" class="form-control" rows="3">{{ categorie.description }}</textarea>
		</div>

		<div class="mb-3 form-check">
			<input type="checkbox" id="est_epi" name="est_epi" class="form-check-input" {% if categorie.est_epi %}checked{% endif %}>
			<label class="form-check-label" for="est_epi">Classée EPI</label>
		</div>

		<div class="mb-3">
			<label for="image">Image :</label>
			<input type="file" id="image" name="image" class="form-control">
			{% if categorie.image %}
				<small class="form-text text-muted">Image actuelle : {{ categorie.image }}</small>
			{% endif %}
		</div>

		<div class="form-actions">
			<button type="submit" class="btn btn-primary">Enregistrer</button>
			<a href="/admin/categories" class="btn btn-secondary">Annuler</a>
		</div>
	</form>

{% endblock %}