{% extends "_layout.twig" %}

{% block body %}

	<h3>Fiche fournisseur</h3>
	<hr>

	{% if fournisseur %}
		<div class="card">
			<div class="card-body">
				<h5 class="card-title">{{ fournisseur.nom }}</h5>
				<ul class="list-group list-group-flush">
					<li class="list-group-item">
						<strong>Email :</strong> 
						{% if fournisseur.email %}
							<a href="mailto:{{ fournisseur.email }}">{{ fournisseur.email }}</a>
						{% else %}
							<em>Non renseigné</em>
						{% endif %}
					</li>
					<li class="list-group-item">
						<strong>Téléphone :</strong> 
						{% if fournisseur.phone %}
							{{ fournisseur.phone }}
						{% else %}
							<em>Non renseigné</em>
						{% endif %}
					</li>
				</ul>
			</div>
		</div>

		<div class="form-actions d-flex gap-2 mt-3">
			<a href="/admin/fournisseurs" class="btn btn-secondary">Retour à la liste</a>
			<a href="/admin/fournisseurs/fournisseur_modification-{{ fournisseur.id }}" class="btn btn-warning">Modifier</a>
			<a href="/admin/fournisseurs/supprimer?id={{ fournisseur.id }}" 
			   onclick="return confirm('Êtes-vous sûr de vouloir supprimer ce fournisseur ? Cette action est irréversible.')" 
			   class="btn btn-danger ms-auto">
				🗑️ Supprimer
			</a>
		</div>
	{% else %}
		<p>Fournisseur non trouvé.</p>
		<a href="/admin/fournisseurs" class="btn btn-secondary">Retour à la liste</a>
	{% endif %}

{% endblock %}