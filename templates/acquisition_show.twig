{% extends "_layout.twig" %}

{% block body %}

	<h3>Acquisition #{{ acquisition.id }}</h3>
	<hr>

	<!-- INFORMATIONS GÉNÉRALES -->
	<div class="card">
		<div class="card-header">
			Informations générales
			{% if acquisition.est_validee %}
				<span class="badge bg-success float-end">✅ Validée</span>
			{% else %}
				<span class="badge bg-warning float-end">⏳ En attente de validation</span>
			{% endif %}
		</div>
		<div class="card-body">
			<div class="row">
				<div class="col-md-6">
					<div class="mb-2">
						<strong>Fournisseur :</strong> 
						{{ acquisition.fournisseur.nom }}
					</div>
					<div class="mb-2">
						<strong>Référence facture :</strong> 
						{{ acquisition.facture_reference }}
					</div>
					<div class="mb-2">
						<strong>Date d'achat :</strong> 
						{{ acquisition.facture_date|date("d/m/Y") }}
					</div>
				</div>
				<div class="col-md-6">
					<div class="mb-2">
						<strong>Saisie par :</strong> 
						{{ acquisition.redacteur.prenom }} {{ acquisition.redacteur.nom }}
					</div>
					<div class="mb-2">
						<strong>Document :</strong> 
						{% if acquisition.facture_document %}
							<a href="/uploads/{{ acquisition.facture_document }}" target="_blank">📄 Voir la facture</a>
						{% else %}
							<span class="text-muted">Aucun document</span>
						{% endif %}
					</div>
					<div class="mb-2">
						<strong>Statut :</strong>
						{% if acquisition.est_validee %}
							<span class="badge bg-success">Validée</span>
						{% else %}
							<span class="badge bg-warning">En attente</span>
						{% endif %}
					</div>
				</div>
			</div>
		</div>
	</div>

	<br>

	<!-- LIGNES D'ACQUISITION -->
	<div class="card">
		<div class="card-header">
			Lignes d'acquisition
			<span class="badge bg-secondary float-end">{{ acquisition.lignes|length }} ligne(s)</span>
		</div>
		<div class="card-body">
			{% if acquisition.lignes %}
				<table class="table table-striped">
					<thead>
						<tr>
							<th>Référence</th>
							<th>Désignation</th>
							<th>Catégorie</th>
							<th>EPI</th>
							<th>Nombre</th>
							<th>Générés</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% set total_equipements = 0 %}
						{% for ligne in acquisition.lignes %}
							{% set total_equipements = total_equipements + ligne.nombre %}
							<tr>
								<td>{{ ligne.reference }}</td>
								<td>{{ ligne.designation }}</td>
								<td>{{ ligne.categorie.libelle }}</td>
								<td>
									{% if ligne.categorie and ligne.categorie.est_epi %}
									<span class="badge bg-success">EPI</span>
									{% else %}
									<span class="badge bg-secondary">Non EPI</span>
									{% endif %}
								</td>
								<td>{{ ligne.nombre }}</td>
								<td>
									{% if ligne.equipements_generes %}
									<span class="badge bg-success">✅ Générés</span>
									{% else %}
									<span class="badge bg-warning">⏳ En attente</span>
									{% endif %}
								</td>
								<td>
									{% if ligne.equipements_generes == 0 %}
										<a href="/admin/acquisitions/ligne_modification-{{ ligne.id }}" class="btn btn-sm btn-warning">Modifier</a>
										<a href="/admin/acquisitions/ligne_supprimer-{{ ligne.id }}" 
										   onclick="return confirm('Supprimer cette ligne ?')" 
										   class="btn btn-sm btn-danger">Supprimer</a>
									{% else %}
										<span class="text-muted">Verrouillée</span>
									{% endif %}
								</td>
							</tr>
						{% endfor %}
					</tbody>
					<tfoot>
						<tr class="table-info">
							<td colspan="3" class="text-end"><strong>Total équipements :</strong></td>
							<td><strong>{{ total_equipements }}</strong></td>
							<td colspan="2"></td>
						</tr>
					</tfoot>
				</table>
			{% else %}
				<p class="text-muted">Aucune ligne d'acquisition.</p>
			{% endif %}
		</div>
	</div>

	<br>

	<!-- BOUTONS D'ACTION -->
	<div class="mt-3">
		<a href="/admin/acquisitions" class="btn btn-secondary">Retour à la liste</a>
		
		<!-- BOUTON VALIDER -->
		{% if not acquisition.est_validee and acquisition.lignes and acquisition.lignes|length > 0 %}
			{% if acquisition.facture_document %}
				<form method="post" action="/admin/acquisitions/valider/{{ acquisition.id }}" style="display: inline;">
					<button type="submit" name="action" value="valider" class="btn btn-success" 
						onclick="return confirm('⚠️ Valider cette acquisition ? Les équipements seront générés définitivement et vous ne pourrez plus modifier les lignes.')">
						✅ Valider l'acquisition
					</button>
				</form>
			{% else %}
				<button class="btn btn-success" disabled title="Veuillez d'abord télécharger la facture">
					✅ Valider l'acquisition
				</button>
				<span class="text-muted ms-2">📄 Facture requise avant validation</span>
			{% endif %}
		{% endif %}
		
		<!-- BOUTON MODIFIER -->
		{% if not acquisition.est_validee %}
			<a href="/admin/acquisitions/acquisition_modification-{{ acquisition.id }}" class="btn btn-primary">✏️ Modifier</a>
		{% else %}
			<span class="text-muted">🔒 Modification verrouillée</span>
		{% endif %}
		
		<!-- BOUTON VOIR LES ÉQUIPEMENTS -->
		{% if acquisition.est_validee %}
			<a href="/admin/equipements?acquisition={{ acquisition.id }}" class="btn btn-success">📋 Voir les équipements</a>
		{% endif %}
	</div>

{% endblock %}