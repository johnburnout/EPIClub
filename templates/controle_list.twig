{% extends "_layout.twig" %}

{% block body %}
    <h3>Liste des contrôles</h3>
    <hr>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Libellé</th>
                <th>Début</th>
                <th>Fin</th>
                <th>Statut</th>
                <th>Contrôleur</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for controle in controles %}
                <tr>
                    <td>{{ controle.libelle }}</td>
                    <td>{{ controle.date_debut|date('d/m/Y H:i') }}</td>
                    <td>{{ controle.date_fin ? controle.date_fin|date('d/m/Y H:i') : '-' }}</td>
                    <td>
                        {% if controle.statut == 'ouvert' %}
                            <span class="badge bg-primary">Ouvert</span>
                        {% elseif controle.statut == 'en_cours' %}
                            <span class="badge bg-warning">En cours</span>
                        {% elseif controle.statut == 'cloture' %}
                            <span class="badge bg-success">Clôturé</span>
                        {% endif %}
                    </td>
                    <td>{{ controle.prenom }} {{ controle.nom }}</td>
                    <td>
                        <a href="/admin/controles/edit/{{ controle.id }}" class="btn btn-sm btn-primary">Voir / Modifier</a>
                        {% if controle.statut != 'cloture' %}
                            <a href="/admin/controles/cloturer/{{ controle.id }}" class="btn btn-sm btn-success" onclick="return confirm('Clôturer ce contrôle ?')">Clôturer</a>
                        {% endif %}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}