{% extends "_layout.twig" %}

{% block body %}
<h3>Contrôle : {{ controle.libelle }}</h3>
<hr>

{% if readonly %}
<div class="alert alert-info">
    {% if controle.statut == 'cloture' %}
    <strong>🔒 Lecture seule :</strong> Ce contrôle est clôturé, vous ne pouvez pas le modifier.
    {% else %}
    <strong>ℹ️ Lecture seule :</strong> Ce contrôle est ouvert mais vous ne disposez pas des droits pour le modifier.
    {% endif %}
</div>
{% endif %}

{% if isAdminEdit and not readonly %}
    <div class="alert alert-warning">
        <strong>⚠️ Attention :</strong> Vous modifiez un contrôle qui ne vous appartient pas 
        (contrôleur : {{ controle.controleur_nom ?? controle.controleur_id }}). 
        Vous pouvez le modifier car il date d'au moins la veille.
    </div>
{% endif %}

<div class="row mb-3">
    <div class="col-md-4">
        <strong>Début :</strong> {{ controle.date_debut|date('d/m/Y H:i') }}
    </div>
    <div class="col-md-4">
        <strong>Statut :</strong>
        {% if controle.statut == 'ouvert' %}
        <span class="badge bg-primary">Ouvert</span>
        {% elseif controle.statut == 'en_cours' %}
        <span class="badge bg-warning">En cours</span>
        {% elseif controle.statut == 'cloture' %}
        <span class="badge bg-success">Clôturé</span>
        {% endif %}
    </div>
    <div class="col-md-4">
        <strong>Contrôleur :</strong> {{ controle.controleur_nom ?? controle.controleur_id }}
        {% if isAdminEdit %}
            <span class="badge bg-warning text-dark">Modifié par admin</span>
        {% endif %}
    </div>
</div>

<hr>

{% if not readonly %}
    <h4>Ajouter des équipements</h4>
    <p>Liste des équipements disponibles (non encore ajoutés à ce contrôle)</p>

    <!-- Filtres, tri et limite pour la liste des équipements disponibles -->
    <form method="get" class="mb-3">
        <input type="hidden" name="section" value="disponibles">
        <!-- LIGNE 1 : Filtres -->
        <div class="row g-3">
            <div class="col-md-2">
                <label for="categorie" class="form-label">Catégorie</label>
                <select name="categorie" id="categorie" class="form-select">
                    <option value="">Toutes les catégories</option>
                    {% for categorie in categories %}
                    <option value="{{ categorie.id }}" {% if filtres.categorie_id == categorie.id %}selected{% endif %}>
                        {{ categorie.libelle }}
                    </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label for="emplacement" class="form-label">Emplacement</label>
                <select name="emplacement" id="emplacement" class="form-select">
                    <option value="">Tous les emplacements</option>
                    <option value="null" {% if filtres.emplacement_id == 'null' %}selected{% endif %}>Non défini</option>
                    {% for emplacement in emplacements %}
                    <option value="{{ emplacement.id }}" {% if filtres.emplacement_id == emplacement.id %}selected{% endif %}>
                        {{ emplacement.libelle }}
                    </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-1">
                <label for="epi" class="form-label">EPI</label>
                <select name="epi" id="epi" class="form-select">
                    <option value="">Tous</option>
                    <option value="1" {% if filtres.epi == '1' %}selected{% endif %}>Oui</option>
                    <option value="0" {% if filtres.epi == '0' %}selected{% endif %}>Non</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="en_service" class="form-label">Statut</label>
                <select name="en_service" id="en_service" class="form-select">
                    <option value="">Tous</option>
                    <option value="oui" {% if filtres.en_service == 'oui' %}selected{% endif %}>En service</option>
                    <option value="non" {% if filtres.en_service == 'non' %}selected{% endif %}>Hors service</option>
                </select>
            </div>
            <!-- FILTRE : Dernier contrôle -->
            <div class="col-md-2">
                <label for="dernier_controle" class="form-label">Dernier contrôle</label>
                <select name="dernier_controle" id="dernier_controle" class="form-select">
                    <option value="">Tous</option>
                    <option value="plus_1_an" {% if filtres.dernier_controle == 'plus_1_an' %}selected{% endif %}>Plus d'un an</option>
                    <option value="moins_1_an" {% if filtres.dernier_controle == 'moins_1_an' %}selected{% endif %}>Moins d'un an</option>
                </select>
            </div>
        </div>
        <!-- LIGNE 2 : Tri, limite et bouton -->
        <div class="row g-3 mt-2">
            <div class="col-md-2">
                <label for="order_by" class="form-label">Trier par</label>
                <select name="order_by" id="order_by" class="form-select">
                    <option value="reference" {% if filtres.order_by == 'reference' %}selected{% endif %}>Référence</option>
                    <option value="libelle" {% if filtres.order_by == 'libelle' %}selected{% endif %}>Nom</option>
                    <option value="categorie" {% if filtres.order_by == 'categorie' %}selected{% endif %}>Catégorie</option>
                    <option value="date_dernier_controle" {% if filtres.order_by == 'date_dernier_controle' %}selected{% endif %}>Dernier contrôle</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="order_dir" class="form-label">Ordre</label>
                <select name="order_dir" id="order_dir" class="form-select">
                    <option value="asc" {% if filtres.order_dir == 'asc' %}selected{% endif %}>Croissant</option>
                    <option value="desc" {% if filtres.order_dir == 'desc' %}selected{% endif %}>Décroissant</option>
                </select>
            </div>
            {% if pagination.total > 5 %}
            <div class="col-md-2">
                <label for="limit" class="form-label">Lignes par page</label>
                <select name="limit" id="limit" class="form-select" onchange="this.form.submit()">
                    <option value="5" {% if filtres.limit == 5 %}selected{% endif %}>5</option>
                    <option value="10" {% if filtres.limit == 10 %}selected{% endif %}>10</option>
                    <option value="25" {% if filtres.limit == 25 %}selected{% endif %}>25</option>
                    <option value="50" {% if filtres.limit == 50 %}selected{% endif %}>50</option>
                    <option value="100" {% if filtres.limit == 100 %}selected{% endif %}>100</option>
                </select>
            </div>
            {% endif %}
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-secondary w-100">Appliquer</button>
            </div>
        </div>
    </form>

    <!-- Liste des équipements disponibles -->
    {% if equipements_disponibles %}
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Référence</th>
                <th>Nom</th>
                <th>Photo</th>                <!-- ⬅️ NOUVEAU -->
                <th>Catégorie</th>
                <th>EPI</th>
                <th>Emplacement</th>
                <th>Dernier contrôle</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for equipement in equipements_disponibles %}
            <tr>
                <td>{{ equipement.reference }}</td>
                <td>{{ equipement.libelle }}</td>
                <td>
                    {% if equipement.photo %}
                        <img src="{{ equipement.photo }}" alt="Photo" style="max-width: 50px; max-height: 50px;" class="img-thumbnail">
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </td>
                <td>{{ equipement.categorie.libelle|default('N/A') }}</td>
                <td>
                    {% if equipement.categorie and equipement.categorie.est_epi %}
                    <span class="badge bg-success">EPI</span>
                    {% elseif equipement.categorie and not equipement.categorie.est_epi %}
                    <span class="badge bg-secondary">Non EPI</span>
                    {% else %}
                    <span class="badge bg-secondary">Non défini</span>
                    {% endif %}
                </td>
                <td>{{ equipement.emplacement.libelle|default('Non défini') }}</td>
                <td>
                    {% if equipement.date_dernier_controle %}
                        {{ equipement.date_dernier_controle|date('d/m/Y') }}
                    {% else %}
                        <span class="text-muted">Jamais</span>
                    {% endif %}
                </td>
                <td>
                    <form method="post" action="/admin/controles/add-equipement/{{ controle.id }}" style="display: inline;">
                        <input type="hidden" name="equipement_id" value="{{ equipement.id }}">
                        <button type="submit" class="btn btn-sm btn-success">Contrôler</button>
                    </form>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <!-- Pagination pour la liste des équipements disponibles -->
    {% if pagination.totalPages > 1 %}
    <div class="row mt-3">
        <div class="col-md-12">
            <nav aria-label="Pagination disponibles">
                <ul class="pagination">
                    {% if pagination.hasPrevious %}
                    <li class="page-item"><a class="page-link" href="{{ paginationUrls.first }}">Premier</a></li>
                    <li class="page-item"><a class="page-link" href="{{ paginationUrls.previous }}">Précédent</a></li>
                    {% else %}
                    <li class="page-item disabled"><span class="page-link">Premier</span></li>
                    <li class="page-item disabled"><span class="page-link">Précédent</span></li>
                    {% endif %}
                    
                    <li class="page-item disabled"><span class="page-link">Page {{ pagination.page }} sur {{ pagination.totalPages }}</span></li>
                    
                    {% if pagination.hasNext %}
                    <li class="page-item"><a class="page-link" href="{{ paginationUrls.next }}">Suivant</a></li>
                    <li class="page-item"><a class="page-link" href="{{ paginationUrls.last }}">Dernier</a></li>
                    {% else %}
                    <li class="page-item disabled"><span class="page-link">Suivant</span></li>
                    <li class="page-item disabled"><span class="page-link">Dernier</span></li>
                    {% endif %}
                </ul>
            </nav>
            <p class="text-muted">Affichage de {{ equipements_disponibles|length }} équipements sur {{ pagination.total }} (page {{ pagination.page }}/{{ pagination.totalPages }})</p>
        </div>
    </div>
    {% endif %}

    {% else %}
    <p class="text-muted">Aucun équipement disponible à ajouter.</p>
    {% endif %}
    <hr>
{% endif %} {# fin du bloc "non readonly" #}

<h4>Équipements déjà dans le contrôle</h4>

<!-- Sélecteur de limite (pagination) pour la liste des lignes -->
<form method="get" class="mb-3">
    <input type="hidden" name="section" value="lignes">
    <div class="row g-3">
        <div class="col-md-2">
            <label for="lignes_limit" class="form-label">Lignes par page</label>
            <select name="lignes_limit" id="lignes_limit" class="form-select" onchange="this.form.submit()">
                <option value="5" {% if lignes_filtres.limit == 5 %}selected{% endif %}>5</option>
                <option value="10" {% if lignes_filtres.limit == 10 %}selected{% endif %}>10</option>
                <option value="25" {% if lignes_filtres.limit == 25 %}selected{% endif %}>25</option>
                <option value="50" {% if lignes_filtres.limit == 50 %}selected{% endif %}>50</option>
                <option value="100" {% if lignes_filtres.limit == 100 %}selected{% endif %}>100</option>
            </select>
        </div>
    </div>
</form>

{% if lignes %}
<table class="table table-striped">
    <thead>
        <tr>
            <th>Équipement</th>
            <th>Photo</th>                <!-- ⬅️ NOUVEAU -->
            <th>Statut</th>
            <th>Remarque</th>
            <th>Date contrôle</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for ligne in lignes %}
        <tr>
            <td>{{ ligne.reference }} - {{ ligne.libelle }}</td>
            <td>
                {% if ligne.photo %}
                    <img src="{{ ligne.photo }}" alt="Photo" style="max-width: 50px; max-height: 50px;" class="img-thumbnail">
                {% else %}
                    <span class="text-muted">—</span>
                {% endif %}
            </td>
            <td>
                {% if ligne.statut == 'a_controler' %}
                <span class="badge bg-secondary">À contrôler</span>
                {% elseif ligne.statut == 'controle_ok' %}
                <span class="badge bg-success">OK</span>
                {% elseif ligne.statut == 'controle_ko' %}
                <span class="badge bg-danger">KO</span>
                {% elseif ligne.statut == 'hors_service' %}
                <span class="badge bg-dark">Hors service</span>
                {% endif %}
            </td>
            <td>{{ ligne.remarque|default('-') }}</td>
            <td>{{ ligne.date_controle ? ligne.date_controle|date('d/m/Y H:i') : '-' }}</td>
            <td>
                {% if not readonly %}
                    <a href="/admin/controles/update-ligne/{{ ligne.id }}" class="btn btn-sm btn-warning">Modifier</a>
                {% else %}
                    <span class="text-muted">Lecture seule</span>
                {% endif %}
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>

<!-- Pagination pour la liste des lignes -->
{% if lignes_pagination.totalPages > 1 %}
<div class="row mt-3">
    <div class="col-md-12">
        <nav aria-label="Pagination lignes">
            <ul class="pagination">
                {% if lignes_pagination.hasPrevious %}
                <li class="page-item"><a class="page-link" href="{{ lignes_paginationUrls.first }}">Premier</a></li>
                <li class="page-item"><a class="page-link" href="{{ lignes_paginationUrls.previous }}">Précédent</a></li>
                {% else %}
                <li class="page-item disabled"><span class="page-link">Premier</span></li>
                <li class="page-item disabled"><span class="page-link">Précédent</span></li>
                {% endif %}
                
                <li class="page-item disabled"><span class="page-link">Page {{ lignes_pagination.page }} sur {{ lignes_pagination.totalPages }}</span></li>
                
                {% if lignes_pagination.hasNext %}
                <li class="page-item"><a class="page-link" href="{{ lignes_paginationUrls.next }}">Suivant</a></li>
                <li class="page-item"><a class="page-link" href="{{ lignes_paginationUrls.last }}">Dernier</a></li>
                {% else %}
                <li class="page-item disabled"><span class="page-link">Suivant</span></li>
                <li class="page-item disabled"><span class="page-link">Dernier</span></li>
                {% endif %}
            </ul>
        </nav>
        <p class="text-muted">Affichage de {{ lignes|length }} lignes sur {{ lignes_pagination.total }} (page {{ lignes_pagination.page }}/{{ lignes_pagination.totalPages }})</p>
    </div>
</div>
{% endif %}

{% else %}
<p class="text-muted">Aucun équipement ajouté à ce contrôle.</p>
{% endif %}

<div class="mt-3">
    <a href="/admin/controles" class="btn btn-secondary">Retour à la liste</a>
    
    {% if controle.statut != 'cloture' %}
        {% if hasPending %}
            <button class="btn btn-success" disabled title="Des équipements sont encore à contrôler">
                Clôturer le contrôle
            </button>
            <span class="text-muted ms-2">(certains équipements sont encore marqués « À contrôler »)</span>
        {% else %}
            <a href="/admin/controles/cloturer/{{ controle.id }}" 
                class="btn btn-success" 
                onclick="return confirm('Clôturer ce contrôle ? Les remarques seront chiffrées et le contrôle ne sera plus modifiable.')">
                Clôturer le contrôle
            </a>
        {% endif %}
    {% endif %}
</div>
{% endblock %}