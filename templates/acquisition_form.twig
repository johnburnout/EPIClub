{% extends "_layout.twig" %}

{% block body %}
	<hr>
	<h3>Acquisition</h3>
	<hr>

	{% if acquisition.id %}
		{% if acquisition.est_validee %}
			{% set is_readonly = 'readonly disabled' %}
		{% endif %}
	{% endif %}

	<form method="post">
		<div class="mb-3">
			<label for="fournisseur_nom">Fournisseur</label>
			<input type="text" class="form-control" list="fournisseurs" name="fournisseur_nom" id="fournisseur_nom" value="{{ acquisition.fournisseur.nom }}" required {{ is_readonly }}/>
			<datalist id="fournisseurs">
				{% for fournisseur in fournisseurs %}
					<option value="{{ fournisseur.nom }}">{{ fournisseur.nom }}</option>
				{% endfor %}
			</datalist>
		</div>

		<div class="mb-3">
			<label for="facture_reference">Référence facture</label>
			<input type="text" class="form-control" name="facture_reference" id="facture_reference" value="{{ acquisition.facture_reference }}" required {{ is_readonly }}>
		</div>

		<div class="mb-3">
			<label for="facture_date">Date achat</label>
			<input type="date" class="form-control" name="facture_date" id="facture_date" value="{{ acquisition.facture_date ? acquisition.facture_date : "now"|date("Y-m-d") }}" required {{ is_readonly }}>
		</div>

		<hr>
		{% if acquisition.id == true %}
			<!-- Formulaire d'ajout de ligne -->
			<div class="row mb-3">
				<div class="col-lg-2">
					<label for="ligne_reference">Référence *</label>
					<input type="text" class="form-control {% if form_errors.ligne_reference %}is-invalid{% endif %}" 
					       list="equipement_references" name="ligne[reference]" id="ligne_reference" 
					       value="{{ ligne_data.reference ?? '' }}" required {{ is_readonly }}/>
					<datalist id="equipement_references">
						{% for equipement in equipements %}
							<option value="{{ equipement.reference }}">{{ equipement.reference }}</option>
						{% endfor %}
					</datalist>
					{% if form_errors.ligne_reference %}
						<div class="invalid-feedback">{{ form_errors.ligne_reference }}</div>
					{% endif %}
				</div>

				<div class="col-lg-4">
					<label for="ligne_libelle">Libellé *</label>
					<input type="text" class="form-control {% if form_errors.ligne_designation %}is-invalid{% endif %}" 
					       list="equipement_libelles" name="ligne[designation]" id="ligne_libelle" 
					       value="{{ ligne_data.designation ?? '' }}" required {{ is_readonly }}/>
					<datalist id="equipement_libelles">
						{% for equipement in equipements %}
							<option value="{{ equipement.libelle }}">{{ equipement.libelle }}</option>
						{% endfor %}
					</datalist>
					{% if form_errors.ligne_designation %}
						<div class="invalid-feedback">{{ form_errors.ligne_designation }}</div>
					{% endif %}
				</div>

				<div class="col-lg-3">
					<label for="ligne_categorie">Catégorie *</label>
					<input type="text" class="form-control {% if form_errors.ligne_categorie %}is-invalid{% endif %}" 
					       list="categories" name="ligne[categorie_libelle]" id="ligne_categorie" 
					       value="{{ ligne_data.categorie_libelle ?? '' }}" required {{ is_readonly }}/>
					<datalist id="categories">
						{% for categorie in categories %}
							<option value="{{ categorie.libelle }}">{{ categorie.libelle }}</option>
						{% endfor %}
					</datalist>
					{% if form_errors.ligne_categorie %}
						<div class="invalid-feedback">{{ form_errors.ligne_categorie }}</div>
					{% endif %}
				</div>

				<div class="col-lg-1">
					<label for="nombre">Nombre *</label>
					<input type="number" class="form-control {% if form_errors.ligne_nombre %}is-invalid{% endif %}" 
					       name="ligne[nombre]" id="nombre" min="1" 
					       value="{{ ligne_data.nombre ?? 1 }}" required {{ is_readonly }}/>
					{% if form_errors.ligne_nombre %}
						<div class="invalid-feedback">{{ form_errors.ligne_nombre }}</div>
					{% endif %}
				</div>

				<!-- ✅ Case à cocher "Regrouper en lot" -->
				<div class="col-lg-1">
					<label for="regrouper_en_lot">Lot</label>
					<input type="checkbox" class="form-check-input mt-4" name="ligne[regrouper_en_lot]" id="regrouper_en_lot" value="1" 
					       {% if ligne_data.regrouper_en_lot %}checked{% endif %}>
				</div>

				<div class="col-lg-2 d-grid">
					{% if not acquisition.est_validee %}
						<button type="submit" class="btn btn-primary mt-4" id="ajout_entree_btn">Ajouter</button>
					{% else %}
						<span class="text-muted mt-4">🔒 Verrouillée</span>
					{% endif %}
				</div>
			</div>

			<hr>
			<h4>Lignes saisies</h4>
			{% if acquisition.lignes %}
				<table class="table table-striped">
					<thead>
						<tr>
							<th>Référence</th>
							<th>Désignation</th>
							<th>Catégorie</th>
							<th>Nombre</th>
							<th>Lot</th>
							<th>EPI</th>   
							<th>Équipements générés</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for ligne in acquisition.lignes %}
							<tr>
								<td>{{ ligne.reference }}</td>
								<td>{{ ligne.designation }}</td>
								<td>{{ ligne.categorie.libelle }}</td>
								<td>{{ ligne.nombre }}</td>
								<td>
									{% if ligne.regrouper_en_lot %}
									<span class="badge bg-info">Lot</span>
									{% else %}
									<span class="badge bg-secondary">Individuel</span>
									{% endif %}
								</td>
								<td>
									{% if ligne.categorie and ligne.categorie.est_epi %}
									<span class="badge bg-success">EPI</span>
									{% else %}
									<span class="badge bg-secondary">Non EPI</span>
									{% endif %}
								</td>
								<td>
									{% if ligne.equipements_generes %}
									<span class="badge bg-success">Générés</span>
									{% else %}
									<span class="badge bg-warning">En attente</span>
									{% endif %}
								</td>
								<td>
									{% if ligne.equipements_generes == 0 and not acquisition.est_validee %}
										<a href="/admin/acquisitions/ligne_modification-{{ ligne.id }}" class="btn btn-sm btn-warning">Modifier</a>
										<a href="/admin/acquisitions/ligne_supprimer-{{ ligne.id }}" 
										   onclick="return confirm('Supprimer cette ligne ?')" 
										   class="btn btn-sm btn-danger">Supprimer</a>
									{% elseif ligne.equipements_generes == 1 %}
										<span class="text-muted">Verrouillée</span>
									{% else %}
										<span class="text-muted">🔒 Acquisition verrouillée</span>
									{% endif %}
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			{% else %}
				<p class="text-muted">Aucune ligne saisie.</p>
			{% endif %}
		{% endif %}

		<!-- BOUTONS D'ACTION -->
		<div class="mt-3">
			{% if acquisition.id == false %}
				<button type="submit" class="btn btn-primary">Enregistrer et saisir les lignes</button>
				<a href="/admin/acquisitions" class="btn btn-secondary">Annuler</a>
			{% else %}
				<a href="/admin/acquisitions" class="btn btn-secondary">Retour à la liste</a>
				<a href="/admin/acquisitions/acquisition-{{ acquisition.id }}" class="btn btn-info">Voir la fiche</a>
			{% endif %}
		</div>
	</form>
{% endblock %}