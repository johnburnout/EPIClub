{% extends "_layout.twig" %}

{% block body %}
	<h3>Equipements</h3>
    <hr>

    <!-- Filtres -->
    <form method="get" class="mb-3">
        <div class="row g-3">
            <!-- Première ligne : filtres -->
            <div class="col-md-3">
                <label for="categorie" class="form-label">Catégorie</label>
                <select name="categorie" id="categorie" class="form-select">
                    <option value="">Toutes les catégories</option>
                    {% for categorie in categories %}
                    <option value="{{ categorie.id }}" {% if filtres.categorie_id == categorie.id %}selected{% endif %}>
                        {{ categorie.libelle }}
                    </option>
                    {% endfor %}
                </select>
            </div>
            
            <!-- Emplacement (avec option "Non défini") -->
            <div class="col-md-2">
                <label for="emplacement" class="form-label">Emplacement</label>
                <select name="emplacement" id="emplacement" class="form-select">
                    <option value="">Tous les emplacements</option>
                    <option value="null" {% if filtres.emplacement_id == 'null' %}selected{% endif %}>Non défini</option>
                    {% for emplacement in emplacements %}
                    <option value="{{ emplacement.id }}" {% if filtres.emplacement_id == emplacement.id %}selected{% endif %}>
                        {{ emplacement.libelle }}
                    </option>
                    {% endfor %}
                </select>
            </div>
            
            <div class="col-md-2">
                <label for="epi" class="form-label">EPI</label>
                <select name="epi" id="epi" class="form-select">
                    <option value="">Tous</option>
                    <option value="1" {% if filtres.epi == '1' %}selected{% endif %}>EPI</option>
                    <option value="0" {% if filtres.epi == '0' %}selected{% endif %}>Non EPI</option>
                </select>
            </div>
            
            <div class="col-md-2">
                <label for="en_service" class="form-label">Statut</label>
                <select name="en_service" id="en_service" class="form-select">
                    <option value="">Tous</option>
                    <option value="oui" {% if filtres.en_service == 'oui' %}selected{% endif %}>En service</option>
                    <option value="non" {% if filtres.en_service == 'non' %}selected{% endif %}>Hors service</option>
                </select>
            </div>
            
            <div class="col-md-2">
                <label for="order_by" class="form-label">Trier par</label>
                <select name="order_by" id="order_by" class="form-select">
                    <option value="categorie" {% if filtres.order_by == 'categorie' %}selected{% endif %}>Catégorie</option>
                    <option value="date_fin" {% if filtres.order_by == 'date_fin' %}selected{% endif %}>Date de fin</option>
                </select>
            </div>
            <div class="col-md-2">
                <label for="order_dir" class="form-label">Ordre</label>
                <select name="order_dir" id="order_dir" class="form-select">
                    <option value="asc" {% if filtres.order_dir == 'asc' %}selected{% endif %}>Croissant</option>
                    <option value="desc" {% if filtres.order_dir == 'desc' %}selected{% endif %}>Décroissant</option>
                </select>
            </div>
        </div>
        
        <!-- Deuxième ligne : limite et boutons -->
        <div class="row g-3 mt-2">
            <div class="col-md-2">
                <label for="limit" class="form-label">Lignes par page</label>
                <select name="limit" id="limit" class="form-select" onchange="this.form.submit()">
                    <option value="5" {% if filtres.limit == 5 %}selected{% endif %}>5</option>
                    <option value="10" {% if filtres.limit == 10 %}selected{% endif %}>10</option>
                    <option value="25" {% if filtres.limit == 25 %}selected{% endif %}>25</option>
                    <option value="50" {% if filtres.limit == 50 %}selected{% endif %}>50</option>
                    <option value="100" {% if filtres.limit == 100 %}selected{% endif %}>100</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-secondary w-100">Appliquer</button>
            </div>
        </div>
    </form>

    <hr>

    <!-- Pagination -->
    <div class="row mt-3">
        <div class="col-md-12">
            <nav aria-label="Pagination">
                <ul class="pagination">
                    {% if pagination.hasPrevious %}
                    <li class="page-item"><a class="page-link" href="{{ paginationUrls.first }}">Premier</a></li>
                    <li class="page-item"><a class="page-link" href="{{ paginationUrls.previous }}">Précédent</a></li>
                    {% else %}
                    <li class="page-item disabled"><span class="page-link">Premier</span></li>
                    <li class="page-item disabled"><span class="page-link">Précédent</span></li>
                    {% endif %}
                    
                    <li class="page-item disabled"><span class="page-link">Page {{ pagination.page }} sur {{ pagination.totalPages }}</span></li>
                    
                    {% if pagination.hasNext %}
                    <li class="page-item"><a class="page-link" href="{{ paginationUrls.next }}">Suivant</a></li>
                    <li class="page-item"><a class="page-link" href="{{ paginationUrls.last }}">Dernier</a></li>
                    {% else %}
                    <li class="page-item disabled"><span class="page-link">Suivant</span></li>
                    <li class="page-item disabled"><span class="page-link">Dernier</span></li>
                    {% endif %}
                </ul>
            </nav>
            <p class="text-muted">Affichage de {{ equipements|length }} équipements sur {{ pagination.total }} (page {{ pagination.page }}/{{ pagination.totalPages }})</p>
        </div>
    </div>

    <hr>

	<table class="table table-striped">
		<thead>
			<tr>
				<th>Référence</th>
				<th>Nom</th>
				<th>Catégorie</th>
				<th>EPI</th>
				<th>Emplacement</th>
				<th>Mise en service</th>
				<th>Fin d'utilisation</th>
				<th>État</th>
				<th>Statut</th>
				<th>Actions</th>
			</tr>
		</thead>
        <tbody>
            {% for equipement in equipements %}
                <tr>
                    <td>{{ equipement.reference }}</td>
                    <td>{{ equipement.libelle }}</td>
                    <td>{{ equipement.categorie.libelle|default('N/A') }}</td>
                    <td>
                        {% if equipement.categorie and equipement.categorie.est_epi %}
                            <span class="badge bg-success">EPI</span>
                        {% elseif equipement.categorie and not equipement.categorie.est_epi %}
                            <span class="badge bg-secondary">Non EPI</span>
                        {% else %}
                            <span class="badge bg-secondary">Non défini</span>
                        {% endif %}
                    </td>
                    <td>{{ equipement.emplacement.libelle|default('Non défini') }}</td>
                    <td>
                        {% if equipement.date_mise_en_service %}
                            {{ equipement.date_mise_en_service|date("d/m/Y") }}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>
                        {% if not equipement.date_fin_utilisation or equipement.date_fin_utilisation > "now"|date("Y-m-d") %}
                        <a href="#" 
                            onclick="alert('Date de fin d\'utilisation : {% if equipement.date_fin_utilisation %}{{ equipement.date_fin_utilisation|date('d/m/Y') }}{% else %}Non définie{% endif %}'); return false;" 
                            style="text-decoration: none; color: inherit;">
                            Toujours en service
                        </a>
                        {% else %}
                        {{ equipement.date_fin_utilisation|date("d/m/Y") }}
                        {% endif %}
                    </td>
                    <td>{{ equipement.etat|default('-') }}</td>
                    <td>{{ equipement.statut|default('-') }}</td>
                    <td>
                        <a href="/equipements/equipement-{{ equipement.id }}" class="btn btn-sm btn-primary">Voir</a>
                        <a href="/equipements/equipement_modification-{{ equipement.id }}" class="btn btn-sm btn-warning">Modifier</a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
	</table>
{% endblock %}