{% extends "_layout.twig" %}

{% block body %}
	<h3>Acquisitions</h3>
	<hr>
	<a href="/admin/acquisitions/nouvelle" class="btn btn-primary">Nouvelle acquisition</a>
	<hr>
	
	<table class="table table-striped">
		<thead>
			<tr>
				<th>ID</th>
				<th>Fournisseur</th>
				<th>Référence facture</th>
				<th>Date</th>
				<th>Statut</th>
				<th>Actions</th>
			</tr>
		</thead>
		<tbody>
			{% for acquisition in acquisitions %}
				<tr>
					<td>{{ acquisition.id }}</td>
					<td>{{ acquisition.fournisseur.nom }}</td>
					<td>{{ acquisition.facture_reference }}</td>
					<td>{{ acquisition.facture_date|date("d/m/Y") }}</td>
					<td>
						{% if acquisition.est_validee %}
							<span class="badge bg-success">✅ Validée</span>
						{% else %}
							<span class="badge bg-warning">⏳ En attente</span>
						{% endif %}
					</td>
					<td>
						<a href="/admin/acquisitions/acquisition-{{ acquisition.id }}" class="btn btn-sm btn-primary">Voir</a>
						
						{% if not acquisition.est_validee %}
							<a href="/admin/acquisitions/acquisition_modification-{{ acquisition.id }}" class="btn btn-sm btn-warning">Modifier</a>
						{% else %}
							<span class="text-muted">🔒 Verrouillée</span>
						{% endif %}
					</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
{% endblock %}